# =============================================================================
# Django Settings
# =============================================================================
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database Configuration
# =============================================================================
# Para Supabase + Render FREE: Use o TRANSACTION POOLER (tem IPv4)
# A conexão direta (db.*.supabase.co) NÃO tem IPv4, apenas IPv6!
#
# FORMATO CORRETO (Transaction Pooler):
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# IMPORTANTE para Render FREE + Supabase:
# 1. Use Connection POOLING (Transaction mode) - TEM IPv4!
# 2. Porta: 6543 (Transaction mode do pooler)
# 3. Configure DATABASE_IPV4 com IP do pooler
#
# Onde encontrar no Supabase:
# Dashboard > Project Settings > Database > Connection Pooling
# Copie a string do modo "Transaction" e substitua [YOUR-PASSWORD]
#
# Exemplo:
# DATABASE_URL=postgresql://postgres.uomjbcuowfgcwhsejatn:SuaSenha@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
DATABASE_URL=postgresql://user:password@host:port/database

# DATABASE_IPV4: IP IPv4 fixo do Pooler (OBRIGATÓRIO para Render FREE)
# Render FREE não suporta IPv6, então forçamos IPv4 do pooler
#
# Como descobrir o IP do pooler:
# Windows PowerShell:
#   nslookup -type=A aws-0-us-east-1.pooler.supabase.com 8.8.8.8
#
# Linux/Mac:
#   dig +short aws-0-us-east-1.pooler.supabase.com A
#
# Você verá IPs como: 44.208.221.186, 52.45.94.125, 44.216.29.125
# Copie QUALQUER UM deles
#
# Exemplo:
# DATABASE_IPV4=44.208.221.186
#
DATABASE_IPV4=

# =============================================================================
# Supabase API & Storage
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# =============================================================================
# Email Configuration (Brevo - Sendinblue)
# =============================================================================
# Usando Brevo API para desenvolvimento e produção
# Mais confiável que SMTP e funciona no Render Free tier

# Email remetente (deve estar verificado no Brevo)
DEFAULT_FROM_EMAIL=seu-email-verificado@dominio.com

# Usar Brevo Web API (recomendado para produção e desenvolvimento)
USE_BREVO_API=True
EMAIL_HOST_PASSWORD=sua-brevo-api-key-aqui

# Para debug local (descomente para ver emails no console)
# USE_BREVO_API=False
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# =============================================================================
# Email Configuration (SMTP) - ALTERNATIVA
# =============================================================================
# Se preferir usar SMTP tradicional ao invés de Brevo API
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=seu-email@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app

# =============================================================================
# Google Books API
# =============================================================================
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Configuração JSON de parceiros comerciais (allowlist e parâmetro de tracking)
# O Tracking ID real é cadastrado no Django Admin e nunca deve ser salvo aqui.
PARTNER_COMMERCIAL_CONFIG=

# =============================================================================
# Social Authentication (OAuth)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# =============================================================================
# AI Providers (valores de exemplo; configure as chaves no ambiente)
# =============================================================================
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
AI_FALLBACK_PROVIDERS=gemini
AI_RATE_LIMIT_COOLDOWN_SECONDS=1200

# =============================================================================
# Payment Gateway (Mercado Pago)
# =============================================================================
MERCADOPAGO_ACCESS_TOKEN=your-access-token
MERCADOPAGO_PUBLIC_KEY=your-public-key

# =============================================================================
# Site Configuration
# =============================================================================
SITE_URL=http://localhost:8000

# =============================================================================
# Redis (opcional - para cache)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# News Agent System - Unsplash API
# =============================================================================
# Para busca automática de imagens em artigos gerados por IA
# Criar conta gratuita em: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# =============================================================================
# WhatsApp Notifications (CallMeBot) - ALERTAS EM TEMPO REAL
# =============================================================================
# Sistema de alertas via WhatsApp para o administrador.
# Notifica imediatamente sobre: conduta suspeita, erros da IA e reclamações.
#
# SETUP CALLMEBOT (gratuito, ~5 minutos):
# 1. Salve o número +34644001121 nos seus contatos do WhatsApp
# 2. Envie para esse número a mensagem exata: "I allow callmebot to send me messages"
# 3. Aguarde receber sua API KEY por WhatsApp (chega em segundos)
# 4. Preencha as variáveis abaixo com seu número e a key recebida
#
# Número do administrador (formato internacional SEM o +, ex: 5511999998888)
WHATSAPP_ADMIN_NUMBER=

# API Key recebida do CallMeBot via WhatsApp
CALLMEBOT_API_KEY=

# =============================================================================
# Monitoring Configuration (Opcional - valores padrão já configurados)
# =============================================================================
# Quantidade de mensagens em 60 segundos para considerar spam
# MONITORING_SPAM_THRESHOLD=5

# Janela de tempo em segundos para detecção de spam
# MONITORING_SPAM_WINDOW_SECONDS=60

# Severidade mínima para enviar alerta WhatsApp (low/medium/high/critical)
# MONITORING_ALERT_MIN_SEVERITY=medium

# =============================================================================
# Cloudflare R2 Storage
# =============================================================================
USE_R2_STORAGE=True
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_CUSTOM_DOMAIN=
